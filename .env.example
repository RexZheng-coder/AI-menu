# Server-side only. Never expose API keys in browser/client code.
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
MENU_AI_PROVIDER=mimo
MENU_PARSE_STRATEGY=vision
MENU_PARSE_DETAIL=accurate
MAX_PARSE_IMAGES=3

# Optional: OCR-first can be enabled explicitly with MENU_PARSE_STRATEGY=ocr_first.
# Optional: Vercel KV rate limiting. Set both to enable IP-based daily/hourly caps on /api/menus/parse.
KV_REST_API_URL=
KV_REST_API_TOKEN=
